# Copia este archivo a .dev.vars para desarrollo local (no lo subas al repo)
TWELVEDATA_API_KEY=tu_api_key_de_twelvedata
# Bearer token de los endpoints de administración (/api/run, /api/backtest,
# /api/admin/*, /api/dataset, /api/paper/reset). Genera uno largo y aleatorio:
#   openssl rand -hex 32
ADMIN_API_KEY=un_token_largo_y_aleatorio
